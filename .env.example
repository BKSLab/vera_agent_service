# --- Приложение ---
LOGGING_CONFIG_PATH=logging.ini

# --- RabbitMQ (очередь agent.requests, AGENT_SERVICE_PLAN.md, Этап 6) ---
# Общий брокер для всех проектов — отдельный репозиторий
# rabbitmq_service_prod (см. его README.md), не поднимается этим
# docker-compose. RABBITMQ_HOST:
#   - venv/тесты прямо на хосте          -> localhost
#   - этот сервис в своём docker-контейнере, брокер на том же хосте
#     (см. extra_hosts в docker-compose.yml)              -> host.docker.internal
#   - реальный прод, брокер на другом сервере              -> его адрес/DNS-имя
RABBITMQ_HOST=host.docker.internal
RABBITMQ_PORT=5672
RABBITMQ_USER=vera_broker
RABBITMQ_PASSWORD=change-me-to-match-rabbitmq_service_prod
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=agent.requests
RABBITMQ_DLQ=agent.requests.dlq

# --- Redis (LangGraph checkpointer, AGENT_SERVICE_PLAN.md, Этап 5) ---
# Общий Redis для всех проектов — отдельный репозиторий redis_service_prod
# (см. его README.md), не поднимается этим docker-compose. REDIS_HOST:
#   - venv/тесты прямо на хосте                            -> localhost
#   - этот сервис в своём docker-контейнере, Redis на том же хосте
#     (см. extra_hosts в docker-compose.yml)                -> host.docker.internal
#   - реальный прод, Redis на другом сервере                -> его адрес/DNS-имя
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=change-me-to-match-redis_service_prod
REDIS_DB=0
REDIS_SESSION_TTL_SECONDS=86400

# --- LLM-провайдер для графа (OpenAI-совместимый API, провайдер конфигурируется — AGENT_VERA_ARCHITECTURE.md) ---
# ВАЖНО: только базовый URL, без /chat/completions — ChatOpenAI
# (langchain-openai, app/clients/llm.py) сам добавляет этот путь при
# вызове; полный путь здесь приводит к задвоению и 404 у провайдера.
LLM_API_KEY=your_llm_api_key
LLM_API_URL=https://api.openai.com/v1
LLM_MODEL=your_llm_model
LLM_TEMPERATURE=0.3

# --- MCP Tools Server (публичный инструмент `vera_rag_kb`) ---
# Транспорт — streamable-http (MCP_SERVICE_PLAN.md в vera_mcp_service, раздел 0.1/0.2, 2026-07-09):
# нет отдельного /sse-пути, весь путь — /mcp (streamable_http_path по умолчанию у FastMCP).
#   - venv прямо на хосте                                      -> localhost
#   - Agent в docker-контейнере, MCP на том же хосте           -> host.docker.internal
#   - MCP на другом сервере                                    -> его адрес/DNS-имя
MCP_SERVER_URL=http://host.docker.internal:9000/mcp
# Реальный поиск через vera_rag_kb делает в vera_rag_service 2 LLM-вызова (query
# expansion + reranker, RAG_SEARCH_TIMEOUT_SECONDS=10.0 в vera_rag_service/.env)
# и на практике занимает 5-8с — меньший таймаут здесь режет живые ответы
# RAG Service раньше времени.
MCP_CALL_TIMEOUT_SECONDS=15.0
MCP_CALL_RETRIES=2

# --- Observability (Arize Phoenix, Этап 9) ---
PHOENIX_ENABLED=true
PHOENIX_OTLP_ENDPOINT=http://localhost:6006/v1/traces
# Agent, MCP и RAG одного окружения должны использовать одинаковое имя.
PHOENIX_PROJECT_NAME=vera-local
# Содержимое пользовательского вопроса и ответа выключено по умолчанию.
# Включать только в локальном/тестовом окружении на безопасных тестовых данных.
PHOENIX_CAPTURE_CONTENT=false
PHOENIX_CONTENT_MAX_CHARS=12000

# --- Запуск (entrypoint.sh) ---
# ВАЖНО: держать равным 1. Каждый worker hypercorn — отдельный процесс с
# собственной памятью: per-session asyncio.Queue (SSE, AGENT_SERVICE_PLAN.md
# раздел 0.1) и RabbitMQ-consumer живут в памяти одного процесса. Больше
# одного worker'а здесь означает несколько независимых consumer'ов и
# рассинхронизацию SSE-очередей — тот же риск, что и несколько реплик
# контейнера (см. допущение "один инстанс" в плане).
HYPERCORN_WORKERS=1
